{
  "rules": [
    {
      "name": "Cisco Hostname",
      "pattern": "(^(\\S+)(>|#))",
      "color": "#66DBFD",
      "backgroundColor": "",
      "caseSensitive": false,
      "enabled": true
    },
    {
      "name": "MAC Address (colon/dash)",
      "pattern": "\\b(?:[a-f0-9]{2}[:-]){5}[a-f0-9]{2}",
      "color": "#E8CC60",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "MAC Address (dot notation)",
      "pattern": "[a-f0-9]{4}\\.[a-f0-9]{4}\\.[a-f0-9]{4}",
      "color": "#E8CC60",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "MAC Address (dash notation)",
      "pattern": "[a-f0-9]{6}\\-[a-f0-9]{6}",
      "color": "#E8CC60",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "IPv4 Address",
      "pattern": "(([0-9]{1,3})\\.){3}([0-9]{1,3})(\\/(3[0-2]|[1-2][0-9]|[0-9]))?",
      "color": "#83F3E8",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "IPv6 Address",
      "pattern": "((?![^\\w:])(([0-9a-f]{1,4}:){1,7}:|:(:[0-9a-f]{1,4}){1,7}|([0-9a-f]{1,4}:){1,7}[0-9a-f]{0,4}(:[0-9a-f]{1,4}){1,7}):?(?![\\w:]))(\\/(12[0-8]|1[0-1][0-9]|[1-9][0-9]|[0-9]))?|(:{2}\\/0)",
      "color": "#83F3E8",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Time Duration",
      "pattern": "\\b([0-9]+[ywdhms])+\\b",
      "color": "#BBE9FF",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Interface (slot/port)",
      "pattern": "([a-zA-Z]+)(\\-?)(([0-9]+\\/)+)([0-9]+)((\\.([0-9]+))|:([0-9]+))?",
      "color": "#66DBFD",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Interface (loopback/multilink)",
      "pattern": "(loopback|multilink)[0-9]+",
      "color": "#66DBFD",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Interface (Linux)",
      "pattern": "(eth|ens|vlan|vxlan|bond|pppoe|tun|l2tpv3|(vm)?br|lo|gre|dum|wg|wlan)([0-9]+)((\\.([0-9]+)){0,2})",
      "color": "#66DBFD",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Interface (tap/enp)",
      "pattern": "(tap[0-9]*i|(enp0s20f)|enp[0-9]s)([0-9]+)((\\.([0-9]+)){0,2})",
      "color": "#66DBFD",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Informational Keywords",
      "pattern": "\\b(idle|active|incomplete|noarp|unknown|collision|(commit(t(ing|ed))?)|(not found))\\b",
      "color": "#FFD8B0",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Negative (U/D, A/D)",
      "pattern": "\\b((u\\/D)|(A\\/D))\\b",
      "color": "#FC7474",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Negative Keywords",
      "pattern": "\\b(disabled?|not enabled|shutdown|fail(ed)?|deleted?|never|error|re(start|boot|load|set)|((dis|not)connect(ed)?)|confirm|den(y|(ied))|((administratively )?down))\\b",
      "color": "#FC7474",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Negative (duplex/invalid)",
      "pattern": "\\b(half(((\\ |-)duplex)?)|invalid|crc|false|no)\\b",
      "color": "#FC7474",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Positive Keywords",
      "pattern": "\\b(yes|established|true|valid|full(((\\ |-)duplex)?))\\b",
      "color": "#B7EE95",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Positive (U/U)",
      "pattern": "\\b(u\\/u)\\b",
      "color": "#B7EE95",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Positive (up/enabled/success)",
      "pattern": "\\b(up|lower_up|enabled?|permit(ted)?||(connect(ed)?)||success(ful(ly)?)?|done|ok)\\b",
      "color": "#B7EE95",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Interface Types",
      "pattern": "\\b(bonding|bridge|dummy|gre|geneve)\\b",
      "color": "#EEE6B5",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Interface Types (L2/VPN)",
      "pattern": "\\b(l2tpv3|loopback|erspan|openvpn|pppoe)\\b",
      "color": "#EEE6B5",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Interface Types (Ethernet/Tunnel)",
      "pattern": "\\b(pseudo(-ethernet|wire)|ethernet|tunnel|vti|((s|c-)?(vlan|tag))|dot1q|vxlan|wireguard)\\b",
      "color": "#EEE6B5",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Interface Types (Wireless)",
      "pattern": "\\b(vif|wirelessmodem|wireless)\\b",
      "color": "#EEE6B5",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Protocols (Routing)",
      "pattern": "\\b(bfd|(e|i)?bgp|igmp(-proxy)?|nhrp|pim|is(-?)is|ospf(6|v(2|3))?|eigrp|rip(v(1|2)|ng)?|rpki|static)\\b",
      "color": "#EBD7FF",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Protocols (Transport/Network)",
      "pattern": "\\b(ipv4|ipv6|ftp|tcp|udp|tftp|scp|ssh|mpls|mtu|ntp|snmp|inspect|icmp|vrrp)\\b",
      "color": "#EBD7FF",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Protocols (Tools)",
      "pattern": "\\b(traceroute6?|ping6?|tcpdump|telnet)\\b",
      "color": "#EBD7FF",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Protocols (VPN/MPLS)",
      "pattern": "\\b(vrf|evpn|l2vpn|l3vpn|ldp|xconnect|xc|LSP)\\b",
      "color": "#EBD7FF",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Protocols (Cast/Mode)",
      "pattern": "\\b((labeled-)?unicast|multicast|broadcast|master|slave|pointopoint|backup|flowspec|vpn(v4|v6))\\b",
      "color": "#EBD7FF",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Services (DHCP/Relay)",
      "pattern": "\\b(broadcast-relay|conntrack-sync|dhcp-relay|dhcp-server|dhcpv6-relay|dhcpv6-server)\\b",
      "color": "#E6B362",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Services (DNS/HTTP)",
      "pattern": "\\b(dns|https?|ipoe-server|lldp|cdp|mdns|pppoe-server)\\b",
      "color": "#E6B362",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Services (SSH/SNMP)",
      "pattern": "\\b(salt-minion|snmp|ssh|sstp-server|tftp-server|webproxy)\\b",
      "color": "#E6B362",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Services (VLAN tagging)",
      "pattern": "\\b((un)?tagged|trunk|access)\\b",
      "color": "#E6B362",
      "backgroundColor": "",
      "caseSensitive": true,
      "enabled": true
    },
    {
      "name": "Quoted Strings",
      "pattern": "('(.*?)')|(\u201c(.*?)\u201d)",
      "color": "#CECECE",
      "backgroundColor": "",
      "caseSensitive": false,
      "enabled": true
    },
    {
      "name": "Numbers",
      "pattern": "\\b[0-9]+\\b",
      "color": "#FFFF75",
      "backgroundColor": "",
      "caseSensitive": false,
      "enabled": true
    }
  ]
}
